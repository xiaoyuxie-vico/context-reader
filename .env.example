# Copy to .env and add your real key. Never commit .env

# Gemini (used if set)
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (used if GEMINI_API_KEY is not set)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # optional, for OpenAI-compatible APIs (e.g. Ollama: http://localhost:11434/v1)
